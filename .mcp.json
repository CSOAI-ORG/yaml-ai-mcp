{
  "name": "yaml-ai-mcp",
  "description": "AI-powered yaml ai MCP server for agents. Supports validate yaml, convert yaml json, lint yaml. By MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "validate_yaml",
      "description": "Validate YAML syntax and report any errors.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          }
        },
        "required": [
          "content"
        ]
      }
    },
    {
      "name": "convert_yaml_json",
      "description": "Convert between YAML and JSON formats.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "direction": {
            "type": "string"
          }
        },
        "required": [
          "content"
        ]
      }
    },
    {
      "name": "lint_yaml",
      "description": "Lint YAML content for style issues and best practices.",
      "parameters": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          }
        },
        "required": [
          "content"
        ]
      }
    },
    {
      "name": "merge_yaml",
      "description": "Merge two YAML documents together.",
      "parameters": {
        "type": "object",
        "properties": {
          "yaml_a": {
            "type": "string"
          },
          "yaml_b": {
            "type": "string"
          },
          "strategy": {
            "type": "string"
          }
        },
        "required": [
          "yaml_a",
          "yaml_b"
        ]
      }
    }
  ]
}